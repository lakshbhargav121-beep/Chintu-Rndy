local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

-- UI SETUP
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "ChintuAFK"
ScreenGui.Enabled = true

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 200, 0, 150)
MainFrame.Position = UDim2.new(0.8, 0, 0.5, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 12)

local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1,0,0,40)
Title.Text = "🔥 CHINTU AFK"
Title.Font = Enum.Font.GothamBold
Title.TextColor3 = Color3.new(1,1,1)
Title.BackgroundTransparency = 1

-- States
local states = {AutoGrab=false, AntiAFK=false}

-- Button Creator
local function CreateButton(text, y, stateKey)
    local Btn = Instance.new("TextButton", MainFrame)
    Btn.Size = UDim2.new(0.8,0,0,40)
    Btn.Position = UDim2.new(0.1,0,y,0)
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.Text = text
    Btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Btn)
    
    Btn.MouseButton1Click:Connect(function()
        states[stateKey] = not states[stateKey]
        Btn.Text = text:split(":")[1] .. ": " .. (states[stateKey] and "ON" or "OFF")
    end)
end

CreateButton("🌱 Auto Grab : OFF", 0.3, "AutoGrab")
CreateButton("🚶 Anti-AFK : OFF", 0.6, "AntiAFK")

-- MAIN LOOP
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local humanoid = char.Humanoid

    -- 1. Anti-AFK Idle Protection
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())

    -- 2. Auto Grab Logic
    if states.AutoGrab then
        local seeds = workspace:FindFirstChild("Seeds") or workspace:FindFirstChild("DroppedItems")
        if seeds then
            for _, s in pairs(seeds:GetChildren()) do
                local target = (s:IsA("BasePart") and s) or (s:FindFirstChild("Handle"))
                if target then
                    humanoid:MoveTo(target.Position)
                    if (hrp.Position - target.Position).Magnitude < 4 then
                        firetouchinterest(hrp, target, 0)
                        firetouchinterest(hrp, target, 1)
                    end
                end
            end
        end
    end

    -- 3. Anti-AFK Random Movement Logic
    if states.AntiAFK then
        if tick() % 20 < 0.1 then -- Har 20 seconds mein move karega
            local randomPos = Vector3.new(math.random(-20, 20), 0, math.random(-20, 20))
            humanoid:MoveTo(hrp.Position + randomPos)
        end
    end
end)
