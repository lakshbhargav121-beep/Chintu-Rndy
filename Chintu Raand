-- Buttons
local states = {AutoGrab=false, AntiAFK=false}

local function CreateButton(text, y, stateKey)
    local Btn = Instance.new("TextButton", MainFrame)
    Btn.Size = UDim2.new(0.8,0,0,35)
    Btn.Position = UDim2.new(0.1,0,y,0)
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.Text = text
    Btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0,6)
    
    Btn.MouseButton1Click:Connect(function()
        states[stateKey] = not states[stateKey]
        Btn.Text = text:split(":")[1] .. ": " .. (states[stateKey] and "ON" or "OFF")
    end)
end

CreateButton("🌱 Auto Grab : OFF", 0.25, "AutoGrab")
CreateButton("🚶 Anti-AFK : OFF", 0.55, "AntiAFK")

-- LOGIC
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if states.AutoGrab then
        local seeds = workspace:FindFirstChild("Seeds") or workspace:FindFirstChild("DroppedItems")
        if seeds then
            for _, s in pairs(seeds:GetChildren()) do
                local target = (s:IsA("BasePart") and s) or (s:FindFirstChild("Handle"))
                if target then
                    char.Humanoid:MoveTo(target.Position)
                    if (char.HumanoidRootPart.Position - target.Position).Magnitude < 4 then
                        firetouchinterest(char.HumanoidRootPart, target, 0)
                        firetouchinterest(char.HumanoidRootPart, target, 1)
                    end
                end
            end
        end
    end

    if states.AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
        if tick() % 15 < 0.1 then 
            local randomPos = Vector3.new(math.random(-15, 15), 0, math.random(-15, 15))
            char.Humanoid:MoveTo(char.HumanoidRootPart.Position + randomPos)
        end
    end
end)
