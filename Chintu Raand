local AutoGold = CreateButton("🟡 Gold Seed : OFF",0.68)
local AutoRainbow = CreateButton("🌈 Rainbow Seed : OFF",0.80)
local AutoStock = CreateButton("🛒 Stock Watch : OFF",0.92)

local gold = false
local rainbow = false
local stock = false

AutoGold.MouseButton1Click:Connect(function()
    gold = not gold
    AutoGold.Text = "🟡 Gold Seed : "..(gold and "ON" or "OFF")
end)

AutoRainbow.MouseButton1Click:Connect(function()
    rainbow = not rainbow
    AutoRainbow.Text = "🌈 Rainbow Seed : "..(rainbow and "ON" or "OFF")
end)

AutoStock.MouseButton1Click:Connect(function()
    stock = not stock
    AutoStock.Text = "🛒 Stock Watch : "..(stock and "ON" or "OFF")
end)
