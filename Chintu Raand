local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

-- UI SETUP
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "ChintuRndy"

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 160, 0, 220) -- Size badhaya buttons ke liye
MainFrame.Position = UDim2.new(0.5, -80, 0.5, -110)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.ClipsDescendants = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

local Stroke = Instance.new("UIStroke", MainFrame)
Stroke.Color = Color3.fromRGB(255, 0, 0)
Stroke.Thickness = 2

local TitleBar = Instance.new("Frame", MainFrame)
TitleBar.Size = UDim2.new(1,0,0,25)
TitleBar.BackgroundColor3 = Color3.fromRGB(35,35,35)
Instance.new("UICorner", TitleBar).CornerRadius = UDim.new(0,8)

local Title = Instance.new("TextLabel", TitleBar)
Title.Size = UDim2.new(1,-25,1,0)
Title.BackgroundTransparency = 1
Title.Text = "🔥 CHINTU RNDY 🍑"
Title.Font = Enum.Font.GothamBold
Title.TextColor3 = Color3.fromRGB(255,255,255)
Title.TextSize = 12

local ButtonContainer = Instance.new("Frame", MainFrame)
ButtonContainer.Size = UDim2.new(1,0,1,-25)
ButtonContainer.Position = UDim2.new(0,0,0,25)
ButtonContainer.BackgroundTransparency = 1

local MinBtn = Instance.new("TextButton", TitleBar)
MinBtn.Size = UDim2.new(0, 25, 0, 25)
MinBtn.Position = UDim2.new(1, -25, 0, 0)
MinBtn.BackgroundTransparency = 1
MinBtn.Text = "-"
MinBtn.TextColor3 = Color3.new(1,1,1)
local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    MainFrame.Size = minimized and UDim2.new(0, 160, 0, 25) or UDim2.new(0, 160, 0, 220)
    ButtonContainer.Visible = not minimized
    MinBtn.Text = minimized and "+" or "-"
end)

local states = {AutoGrab=false, AutoHarvest=false, AutoPlant=false, AntiAFK=false}

local function CreateButton(text, y, stateKey)
    local Btn = Instance.new("TextButton", ButtonContainer)
    Btn.Size = UDim2.new(0.8,0,0,30)
    Btn.Position = UDim2.new(0.1,0,0,y)
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.Text = text
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.TextSize = 11
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0,4)
    
    Btn.MouseButton1Click:Connect(function()
        states[stateKey] = not states[stateKey]
        Btn.Text = text:split(":")[1] .. ": " .. (states[stateKey] and "ON" or "OFF")
    end)
end

CreateButton("🌱 AUTO Grab: OFF", 10, "AutoGrab")
CreateButton("🍀 AUTO HARVEST: OFF", 45, "AutoHarvest")
CreateButton("🚜 AUTO Plant: OFF", 80, "AutoPlant")
CreateButton("🚶 ANTI AFK: OFF", 115, "AntiAFK")

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    -- Grab
    if states.AutoGrab then
        local seeds = workspace:FindFirstChild("Seeds") or workspace:FindFirstChild("DroppedItems")
        if seeds then
            for _, s in pairs(seeds:GetChildren()) do
                if s:IsA("BasePart") then
                    char.Humanoid:MoveTo(s.Position)
                    firetouchinterest(char.HumanoidRootPart, s, 0)
                    firetouchinterest(char.HumanoidRootPart, target, 1)
                end
            end
        end
    end

    -- Harvest & Plant Logic
    if (states.AutoHarvest or states.AutoPlant) and workspace:FindFirstChild("Plots") then
        for _, p in pairs(workspace.Plots:GetChildren()) do
            -- Logic: Agar crop ready hai toh harvest
            if states.AutoHarvest and p:FindFirstChild("ReadyToHarvest") and p.ReadyToHarvest.Value == true then
                char.Humanoid:MoveTo(p.Position)
                if (char.HumanoidRootPart.Position - p.Position).Magnitude < 5 then
                    fireclickdetector(p.ClickDetector)
                end
            -- Logic: Agar plot khali hai toh plant
            elseif states.AutoPlant and p:FindFirstChild("Empty") and p.Empty.Value == true then
                char.Humanoid:MoveTo(p.Position)
                if (char.HumanoidRootPart.Position - p.Position).Magnitude < 5 then
                    fireclickdetector(p.ClickDetector)
                end
            end
        end
    end

    -- AFK
    if states.AntiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
        if tick() % 15 < 0.1 then 
            char.Humanoid:MoveTo(char.HumanoidRootPart.Position + Vector3.new(math.random(-15,15),0,math.random(-15,15)))
        end
    end
end)
